# ============================================================================
# smartcloset environment variables
# Copy to `.env` and fill in the values for features you want to enable.
# Missing keys degrade gracefully — the app still works as a wardrobe manager.
# ============================================================================

# --- Supabase (REQUIRED for auth, cloud sync) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Google Cloud Vision (AI clothing analysis, body profile, lens search) ---
# Create a Vision API key at: https://console.cloud.google.com/apis/credentials
GOOGLE_VISION_API_KEY=your_google_vision_api_key
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_VISION_LOCATION=us-west1

# --- Google Custom Search (shopping results from reverse image search) ---
# Create a CSE at: https://programmablesearchengine.google.com/
# and an API key at: https://console.cloud.google.com/apis/credentials
GOOGLE_CSE_ID=your_custom_search_engine_id
GOOGLE_CSE_API_KEY=your_google_cse_api_key

# --- OpenAI (optional alternative to Google Vision) ---
OPENAI_API_KEY=

# --- Social auth (optional — stubs if missing) ---
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
APPLE_SERVICE_ID=

# --- Sentry crash reporting ---
# Create a Sentry project at https://sentry.io → Settings → Projects → Create
# Copy the DSN from: Settings → Projects → [your project] → Client Keys (DSN)
SENTRY_DSN=https://your-dsn@sentry.io/your-project-id

# --- App meta ---
APP_ENV=development
APP_VERSION=1.0.0

# --- Feature flags ---
ENABLE_AI_SUGGESTIONS=true
ENABLE_VISION_API=true
ENABLE_AI_BODY_ANALYSIS=true
ENABLE_REVERSE_IMAGE_SEARCH=true
ENABLE_OFFLINE_MODE=true

# --- Storage / limits ---
MAX_IMAGE_SIZE_MB=10
IMAGE_QUALITY=80
THUMBNAIL_SIZE=300
